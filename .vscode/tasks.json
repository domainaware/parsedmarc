{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Dev Dashboard: Up",
      "type": "shell",
      "command": "docker compose -f docker-compose.dashboard-dev.yml up -d",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new"
      }
    },
    {
      "label": "Dev Dashboard: Bootstrap (compose up + import dashboards + sample data)",
      "type": "shell",
      "command": "./dashboard-dev-bootstrap.sh",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "clear": true
      }
    }
  ]
}
